<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-800"><%= pengguna.nama %></h1>
    <p class="text-slate-500">Maklumat pengguna</p>
  </div>
</div>

<div class="bg-white rounded-lg shadow p-6 space-y-4">
  <dl class="grid md:grid-cols-2 gap-x-8 gap-y-4">
    <div>
      <dt class="text-sm text-slate-500">Nama</dt>
      <dd class="font-medium"><%= pengguna.nama %></dd>
    </div>
    <div>
      <dt class="text-sm text-slate-500">E-mel</dt>
      <dd class="font-medium"><%= pengguna.email %></dd>
    </div>
  </dl>

  <div class="pt-4 border-t">
    <a href="/pengguna" class="px-4 py-2 rounded border border-slate-300 hover:bg-slate-50">Kembali ke senarai</a>
  </div>
</div>
