<div class="max-w-md mx-auto">
  <div class="mb-6 text-center">
    <h1 class="text-2xl font-bold text-slate-800">Log Masuk</h1>
    <p class="text-slate-500">Masuk untuk mengurus sistem aduan.</p>
  </div>

  <!-- Papar ralat log masuk jika ada -->
  <% if (ralat) { %>
    <div class="mb-4 rounded border border-red-300 bg-red-50 text-red-800 px-4 py-3 text-sm">
      <%= ralat %>
    </div>
  <% } %>

  <form method="POST" action="/login" class="bg-white rounded-lg shadow p-6 space-y-4">
    <div>
      <label class="block text-sm font-medium mb-1">E-mel <span class="text-red-500">*</span></label>
      <input type="email" name="email" value="<%= nilai.email || '' %>" autofocus
        class="w-full border border-slate-300 rounded px-3 py-2" />
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">Kata Laluan <span class="text-red-500">*</span></label>
      <input type="password" name="password"
        class="w-full border border-slate-300 rounded px-3 py-2" />
    </div>

    <button type="submit" class="w-full bg-blue-700 text-white px-5 py-2 rounded hover:bg-blue-600">
      Log Masuk
    </button>
  </form>
</div>
